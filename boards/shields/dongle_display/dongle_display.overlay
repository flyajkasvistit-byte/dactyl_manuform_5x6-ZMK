&i2c0 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>;


    sda-pin = <8>;  
    scl-pin = <6>;  

    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>; 
        width = <128>;
        height = <64>;
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <63>;
        segment-remap;
        com-invdir;
        prechargep = <0x22>;
    };
};